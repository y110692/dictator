# Default provider: OpenRouter speech-to-text.
# You can replace these with another compatible provider if it accepts
# base64 audio JSON at /audio/transcriptions.
TRANSCRIPTION_API_KEY=your_api_key_here
TRANSCRIPTION_MODEL=openai/whisper-1
TRANSCRIPTION_FALLBACK_MODEL=
TRANSCRIPTION_API_URL=https://openrouter.ai/api/v1/audio/transcriptions
TRANSCRIPTION_TIMEOUT=120
TRANSCRIPTION_LANGUAGE=ru
TRANSCRIPTION_PROMPT=Transcribe this Russian speech to plain text. Return only the transcript.
TRANSCRIPTION_REFERER=https://localhost/dictator
TRANSCRIPTION_TITLE=Dictator
DICTATOR_HOTKEY=f10
DICTATOR_LOG_FILE=runtime/dictator.log

# TRANSCRIPTION_PROMPT is only used with legacy chat/completions endpoints.
# Backward compatibility: existing OPENROUTER_* variables are still supported.
